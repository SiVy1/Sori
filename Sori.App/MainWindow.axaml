<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:App.Converters"
        xmlns:ctrl="clr-namespace:App.Controls"
        x:Class="App.MainWindow"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Background="#0A0A0C"
        Title="Sori"
        KeyboardNavigation.TabNavigation="None">

    <Window.Resources>
        <conv:UrlToBitmapConverter x:Key="UrlBitmap" />
        <conv:DurationToTextConverter x:Key="DurationText" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
            <Setter Property="Foreground" Value="#E8E8E8" />
        </Style>

        <!-- Compact slider -->
        <Style Selector="Slider">
            <Setter Property="MinHeight" Value="12" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="Slider /template/ Track">
            <Setter Property="MinHeight" Value="3" />
        </Style>
        <Style Selector="Slider /template/ Thumb">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>

        <!-- Player buttons: no focus rect, subtle hover -->
        <Style Selector="Button.player-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style Selector="Button.player-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.player-btn:focus /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Home card hover -->
        <Style Selector="Button.home-card">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.home-card:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#141416" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <!-- Track row hover -->
        <Style Selector="Button.track-row">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.track-row:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#141416" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto"
          ColumnDefinitions="*,Auto">

        <!-- Modal overlay -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#00000080"
                IsVisible="{Binding IsModalOpen}"
                ZIndex="100">
            <Grid DataContext="{Binding Search}">
                <Border Width="640"
                        MaxHeight="560"
                        Margin="0,80,0,0"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Background="#111113"
                        BorderBrush="#2A2A2C"
                        BorderThickness="1"
                        CornerRadius="12"
                        BoxShadow="0 8 32 0 #00000080">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <!-- Search input -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              Margin="16,10,16,0"
                              VerticalAlignment="Center">
                            <TextBlock Text="Ctrl+Space"
                                       Foreground="#666668"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       IsVisible="{Binding !IsCommandMode}" />
                            <TextBlock Text="›"
                                       Foreground="#A78BFA"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       IsVisible="{Binding IsCommandMode}" />
                            <TextBox x:Name="ModalSearchBox"
                                     Grid.Column="1"
                                     Height="22"
                                     Watermark="Search or type &gt; for commands..."
                                     Text="{Binding SearchQuery}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Foreground="#FFFFFF" />
                            <Button Grid.Column="2"
                                    Content="Search"
                                    Height="22"
                                    Command="{Binding SearchCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#88888A"
                                    Padding="4,0"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding !IsCommandMode}" />
                        </Grid>

                        <!-- Command palette hint -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding IsCommandMode}"
                                Background="#1A1A1C"
                                Padding="16,8"
                                Margin="0,8,0,0"
                                DataContext="{Binding}">
                            <TextBlock Text="Command mode"
                                       Foreground="#A78BFA"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>

                        <!-- Results -->
                        <Grid Grid.Row="2"
                              Margin="16,8,16,16"
                              RowDefinitions="Auto,*">

                            <!-- Command palette -->
                            <ListBox x:Name="CommandListBox"
                                     Grid.Row="1"
                                     ItemsSource="{Binding CommandItems}"
                                     SelectedIndex="{Binding ModalSelectedIndex, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsVisible="{Binding IsCommandMode}">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="8,6" />
                                        <Setter Property="Margin" Value="0,2" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Focusable" Value="True" />
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="#1A1A1C" />
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="#222223" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto">
                                             <StackPanel Spacing="1">
                                                 <TextBlock Text="{Binding Title}"
                                                            Foreground="#E8E8E8"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            TextTrimming="CharacterEllipsis" />
                                                 <TextBlock Text="{Binding Subtitle}"
                                                            Foreground="#88888A"
                                                            FontSize="11"
                                                            TextTrimming="CharacterEllipsis" />
                                             </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Shortcut}"
                                                       Foreground="#666668"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Unified search results with keyboard nav -->
                            <ListBox x:Name="ModalListBox"
                                     Grid.Row="1"
                                     ItemsSource="{Binding ModalItems}"
                                     SelectedIndex="{Binding ModalSelectedIndex, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsVisible="{Binding !IsCommandMode}">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="8,6" />
                                        <Setter Property="Margin" Value="0,2" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Focusable" Value="True" />
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="#1A1A1C" />
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="#222223" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="36,*,Auto">
                                            <Image Width="36"
                                                   Height="36"
                                                   Stretch="UniformToFill"
                                                   Source="{Binding ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />
                                            <StackPanel Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Spacing="1">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#E8E8E8"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Subtitle}"
                                                           Foreground="#88888A"
                                                           FontSize="11" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Kind}"
                                                       Foreground="#666668"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Home -->
        <ScrollViewer Grid.Row="0"
                      Grid.Column="0"
                      Margin="24,24,24,0"
                      IsVisible="{Binding IsHomeView}">
            <StackPanel Spacing="32"
                        DataContext="{Binding Home}">
                <TextBlock Text="Home"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FFFFFF" />

                <TextBlock Text="Loading..."
                           IsVisible="{Binding IsHomeLoading}"
                           Foreground="#666668" />

                <TextBlock Text="{Binding HomeError}"
                           Foreground="Tomato"
                           IsVisible="{Binding HomeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <ItemsControl ItemsSource="{Binding HomeSections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFF" />
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ctrl:AdaptiveGrid ItemWidth="160" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                                     <Button Classes="home-card"
                                                             Command="{Binding DataContext.OpenHomeItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             CommandParameter="{Binding}"
                                                             HorizontalAlignment="Stretch"
                                                             Margin="8">
                                                 <StackPanel Spacing="8">
                                                     <Border Width="140"
                                                             Height="140"
                                                             Background="#1A1A1C"
                                                             CornerRadius="6"
                                                             ClipToBounds="True">
                                                         <Image Stretch="UniformToFill"
                                                                Source="{Binding ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />
                                                     </Border>
                                                     <StackPanel Spacing="2">
                                                         <TextBlock Text="{Binding Title}"
                                                                    Foreground="#E8E8E8"
                                                                    FontSize="14"
                                                                    FontWeight="SemiBold"
                                                                    TextTrimming="CharacterEllipsis" />
                                                         <TextBlock Text="{Binding Subtitle}"
                                                                    Foreground="#88888A"
                                                                    FontSize="12"
                                                                    TextTrimming="CharacterEllipsis" />
                                                     </StackPanel>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Collection Detail -->
        <ScrollViewer Grid.Row="0"
                      Grid.Column="0"
                      IsVisible="{Binding IsCollectionDetailView}"
                      Margin="24,24,24,0">
            <StackPanel Spacing="20">

                <Button Content="Back"
                        Command="{Binding BackToSearchCommand}"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#88888A"
                        Padding="0" />

                <Grid ColumnDefinitions="160,*" ColumnSpacing="24">
                    <Border Width="160"
                            Height="160"
                            Background="#1A1A1C"
                            CornerRadius="6"
                            ClipToBounds="True">
                        <Image Stretch="UniformToFill"
                               Source="{Binding CollectionDetail.ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Spacing="8">
                        <Button Content="Play All"
                                Command="{Binding PlayCollectionCommand}"
                                Background="#1A1A1C"
                                BorderBrush="#2A2A2C"
                                BorderThickness="1"
                                Foreground="#E8E8E8"
                                Padding="12,4"
                                HorizontalAlignment="Left" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding CollectionDetail.CollectionType}"
                                       Foreground="#88888A"
                                       FontSize="12" />

                            <TextBlock Text="{Binding CollectionDetail.Title}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF" />

                            <TextBlock Text="{Binding CollectionDetail.Subtitle}"
                                       Foreground="#88888A"
                                       FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Loading tracks..."
                           IsVisible="{Binding CollectionDetail.IsLoading}"
                           Foreground="#666668" />

                <TextBlock Text="{Binding CollectionDetail.Error}"
                           IsVisible="{Binding CollectionDetail.HasError}"
                           Foreground="Tomato" />

                <TextBlock Text="Tracks"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#FFFFFF" />

                <ItemsControl ItemsSource="{Binding CollectionDetail.Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="track-row"
                                    Command="{Binding DataContext.PlayCollectionTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,6">
                                <Button.ContextMenu>
                                    <ContextMenu Background="#1A1A1C"
                                                 BorderBrush="#2A2A2C"
                                                 BorderThickness="1"
                                                 CornerRadius="6">
                                        <MenuItem Header="Play next"
                                                  Command="{Binding DataContext.AddNextCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Add to queue"
                                                  Command="{Binding DataContext.AddToQueueEndCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#E8E8E8"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ArtistName}"
                                                   Foreground="#88888A"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                                Text="{Binding Duration, Converter={StaticResource DurationText}}"
                                                Foreground="#666668"
                                                FontSize="12"
                                                VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No tracks found."
                           Foreground="#666668"
                           IsVisible="{Binding CollectionDetail.IsEmpty}" />

            </StackPanel>
        </ScrollViewer>

        <!-- Artist Detail -->
        <ScrollViewer Grid.Row="0"
                      Grid.Column="0"
                      IsVisible="{Binding IsArtistDetailView}"
                      Margin="24,24,24,0">
            <StackPanel Spacing="20">

                <Button Content="Back"
                        Command="{Binding BackToSearchCommand}"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#88888A"
                        Padding="0" />

                <Grid ColumnDefinitions="160,*" ColumnSpacing="24">
                    <Border Width="160"
                            Height="160"
                            Background="#1A1A1C"
                            CornerRadius="6"
                            ClipToBounds="True">
                        <Image Stretch="UniformToFill"
                               Source="{Binding ArtistDetail.ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Spacing="4">
                        <TextBlock Text="Artist"
                                   Foreground="#88888A"
                                   FontSize="12" />

                        <TextBlock Text="{Binding ArtistDetail.Name}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF" />

                        <TextBlock Text="{Binding ArtistDetail.Subtitle}"
                                   Foreground="#88888A"
                                   FontSize="13" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Loading artist..."
                           IsVisible="{Binding ArtistDetail.IsLoading}"
                           Foreground="#666668" />

                <TextBlock Text="{Binding ArtistDetail.Error}"
                           Foreground="Tomato" />

                <StackPanel IsVisible="{Binding ArtistDetail.HasTopSongs}" Spacing="12">
                    <TextBlock Text="Top songs"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#FFFFFF" />

                    <ItemsControl ItemsSource="{Binding ArtistDetail.TopSongs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="track-row"
                                        Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,6">
                                    <Grid ColumnDefinitions="*,Auto">
                                         <StackPanel Spacing="2">
                                             <TextBlock Text="{Binding Title}"
                                                        Foreground="#E8E8E8"
                                                        FontSize="14"
                                                        FontWeight="SemiBold"
                                                        TextTrimming="CharacterEllipsis" />
                                             <TextBlock Text="{Binding AlbumTitle}"
                                                        Foreground="#88888A"
                                                        FontSize="12"
                                                        TextTrimming="CharacterEllipsis" />
                                         </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                    Text="{Binding Duration, Converter={StaticResource DurationText}}"
                                                    Foreground="#666668"
                                                    FontSize="12"
                                                    VerticalAlignment="Center" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel IsVisible="{Binding ArtistDetail.HasAlbums}" Spacing="12">
                    <TextBlock Text="Albums"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#FFFFFF" />

                    <ItemsControl ItemsSource="{Binding ArtistDetail.Albums}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="40,*" Margin="0,6">
                                    <Image Width="40"
                                           Height="40"
                                           Stretch="UniformToFill"
                                           Source="{Binding ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />

                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Spacing="2">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#E8E8E8"
                                                   FontSize="14"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ArtistName}"
                                                   Foreground="#88888A"
                                                   FontSize="12" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel IsVisible="{Binding ArtistDetail.HasSingles}" Spacing="12">
                    <TextBlock Text="Singles"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#FFFFFF" />

                    <ItemsControl ItemsSource="{Binding ArtistDetail.Singles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="40,*" Margin="0,6">
                                    <Image Width="40"
                                           Height="40"
                                           Stretch="UniformToFill"
                                           Source="{Binding ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />

                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Spacing="2">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#E8E8E8"
                                                   FontSize="14"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ArtistName}"
                                                   Foreground="#88888A"
                                                   FontSize="12" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Queue -->
        <Border Grid.Row="0"
                Grid.Column="1"
                BorderBrush="#151517"
                BorderThickness="1,0,0,0"
                Padding="24,28"
                Width="300"
                IsVisible="{Binding DataContext.IsQueueVisible, RelativeSource={RelativeSource AncestorType=Window}}"
                DataContext="{Binding Queue}">
            <Grid RowDefinitions="Auto,Auto,Auto,*">
                <TextBlock Text="Queue"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#FFFFFF" />

                <!-- Empty state -->
                <StackPanel Grid.Row="1"
                            Margin="0,20,0,0"
                            Spacing="4"
                            IsVisible="{Binding IsQueueEmpty}">
                    <TextBlock Text="Queue is empty"
                               Foreground="#666668"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Play something to start building your queue."
                               Foreground="#666668"
                               FontSize="12" />
                </StackPanel>

                <!-- Now playing -->
                <StackPanel Grid.Row="1"
                            Margin="0,20,0,0"
                            Spacing="8"
                            IsVisible="{Binding IsNowPlayingVisible}">
                    <TextBlock Text="Now playing"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#A78BFA" />
                    <Grid ColumnDefinitions="32,*" Margin="0,0,0,10">
                        <Border Width="32"
                                Height="32"
                                CornerRadius="3"
                                ClipToBounds="True"
                                Background="#1A1A1C">
                            <Image Stretch="UniformToFill"
                                   Source="{Binding NowPlayingItem.ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                                        <TextBlock Text="{Binding NowPlayingItem.Title}"
                                                   Foreground="#E8E8E8"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding NowPlayingItem.ArtistName}"
                                                   Foreground="#88888A"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Up next -->
                <StackPanel Grid.Row="2"
                            Margin="0,16,0,0"
                            Spacing="8"
                            IsVisible="{Binding !IsQueueEmpty}">
                    <TextBlock Text="Up next"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#666668" />
                    <ItemsControl ItemsSource="{Binding UpNextItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="32,*" Margin="0,0,0,10">
                                    <Border Width="32"
                                            Height="32"
                                            CornerRadius="3"
                                            ClipToBounds="True"
                                            Background="#1A1A1C">
                                        <Image Stretch="UniformToFill"
                                               Source="{Binding ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Spacing="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#E8E8E8"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ArtistName}"
                                                   Foreground="#88888A"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom player -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                BorderBrush="#151517"
                BorderThickness="0,1,0,0"
                Background="#0D0D0F"
                Padding="16,8"
                DataContext="{Binding Player}">
            <Grid RowDefinitions="Auto,*">
                <!-- Error toast -->
                <Border IsVisible="{Binding HasPlaybackError}"
                        Background="#2D1B1B"
                        BorderBrush="#5C3A3A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <TextBlock Text="⚠"
                                   Foreground="Tomato"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PlaybackError}"
                                   Foreground="#E8A0A0"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*,Auto">
                <!-- Left: Track info -->
                <Grid ColumnDefinitions="40,*"
                      Grid.Column="0"
                      Margin="0,0,20,0">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="3"
                                ClipToBounds="True"
                                Background="#1A1A1C">
                            <Image Stretch="UniformToFill"
                                   Source="{Binding CurrentPlaybackSnapshot.CurrentTrack.ThumbnailUrl, Converter={StaticResource UrlBitmap}}" />
                        </Border>

                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Spacing="1">
                            <TextBlock Text="{Binding CurrentTrackTitle}"
                                       Foreground="#E8E8E8"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding CurrentTrackArtist}"
                                       Foreground="#88888A"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <TextBlock Text="{Binding QueueIndexText}"
                                       Foreground="#666668"
                                       FontSize="10"
                                       IsVisible="{Binding QueueIndexText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <TextBlock Text="{Binding PlaybackError}"
                                       Foreground="Tomato"
                                       FontSize="10"
                                       IsVisible="{Binding HasPlaybackError}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Center: Progress + Controls -->
                <StackPanel Grid.Column="1"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="{Binding PlaybackPositionText}"
                                   Foreground="#666668"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="PositionSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding PlaybackDurationSeconds}"
                                Margin="6,0"
                                Value="{Binding PlaybackPositionSeconds, Mode=TwoWay}"
                                IsEnabled="{Binding CanSeek}"
                                Foreground="#E8E8E8"
                                Background="#222223" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding PlaybackDurationText}"
                                   Foreground="#666668"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="Loading..."
                               Foreground="#666668"
                               FontSize="10"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding IsPlaybackLoading}" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding !IsPlaybackLoading}">
                        <Button Classes="player-btn"
                                Command="{Binding PreviousCommand}"
                                ToolTip.Tip="Previous">
                            <Path Data="{StaticResource IconPrev}"
                                  Fill="#88888A"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform" />
                        </Button>
                        <Button Classes="player-btn"
                                Command="{Binding TogglePlayPauseCommand}"
                                ToolTip.Tip="Play / Pause">
                            <Grid>
                                <Path Data="{StaticResource IconPlay}"
                                      Fill="#E8E8E8"
                                      Width="18"
                                      Height="18"
                                      Stretch="Uniform"
                                      IsVisible="{Binding !IsPlaying}" />
                                <Path Data="{StaticResource IconPause}"
                                      Fill="#E8E8E8"
                                      Width="18"
                                      Height="18"
                                      Stretch="Uniform"
                                      IsVisible="{Binding IsPlaying}" />
                            </Grid>
                        </Button>
                        <Button Classes="player-btn"
                                Command="{Binding NextCommand}"
                                ToolTip.Tip="Next">
                            <Path Data="{StaticResource IconNext}"
                                  Fill="#88888A"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Queue toggle + Shuffle + Repeat + Volume -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Margin="20,0,0,0">
                    <Button Classes="player-btn"
                            Command="{Binding DataContext.ToggleQueueCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip.Tip="Toggle queue">
                        <Grid>
                            <TextBlock Text="Queue"
                                       Foreground="#88888A"
                                       FontSize="10"
                                       IsVisible="{Binding !DataContext.IsQueueVisible, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <TextBlock Text="Queue"
                                       Foreground="#A78BFA"
                                       FontSize="10"
                                       IsVisible="{Binding DataContext.IsQueueVisible, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </Grid>
                    </Button>
                    <Button Classes="player-btn"
                            Command="{Binding DataContext.Queue.ToggleShuffleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip.Tip="Shuffle">
                        <Grid>
                            <TextBlock Text="{Binding DataContext.Queue.ShuffleText, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Foreground="#88888A"
                                       FontSize="10"
                                       IsVisible="{Binding !DataContext.Queue.ShuffleEnabled, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <TextBlock Text="{Binding DataContext.Queue.ShuffleText, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Foreground="#A78BFA"
                                       FontSize="10"
                                       IsVisible="{Binding DataContext.Queue.ShuffleEnabled, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </Grid>
                    </Button>
                    <Button Classes="player-btn"
                            Command="{Binding DataContext.Queue.CycleRepeatModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip.Tip="Repeat">
                        <Grid>
                            <TextBlock Text="{Binding DataContext.Queue.RepeatModeText, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Foreground="#88888A"
                                       FontSize="10"
                                       IsVisible="{Binding !DataContext.Queue.IsRepeatActive, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <TextBlock Text="{Binding DataContext.Queue.RepeatModeText, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Foreground="#A78BFA"
                                       FontSize="10"
                                       IsVisible="{Binding DataContext.Queue.IsRepeatActive, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </Grid>
                    </Button>
                    <Path Data="{StaticResource IconVolume}"
                          Fill="#666668"
                          Width="12"
                          Height="12"
                          Stretch="Uniform"
                          VerticalAlignment="Center" />
                    <Slider x:Name="VolumeSlider"
                            Width="72"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding PlaybackVolumePercent, Mode=TwoWay}"
                            Foreground="#E8E8E8"
                            Background="#222223" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Grid>
</Window>