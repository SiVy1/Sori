<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="App.MainWindow"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Background="#111214"
        Title="Sori">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#18191D" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#2A2B31" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#18191D" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#2A2B31" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,92"
          ColumnDefinitions="230,*,340">

        <!-- Sidebar -->
        <Border Grid.RowSpan="3"
                Grid.Column="0"
                BorderBrush="#25262B"
                BorderThickness="0,0,1,0"
                Padding="24">

            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="Sori"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2" />

                    <TextBlock Text="minimal music client"
                               FontSize="12"
                               Foreground="#77777D" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,42,0,0"
                            Spacing="10">

                    <Border Background="#1B1C21"
                            CornerRadius="10"
                            Padding="12,10">
                        <TextBlock Text="Home"
                                   Foreground="#A78BFA"
                                   FontWeight="SemiBold" />
                    </Border>

                    <TextBlock Text="Search"
                               Foreground="#CFCFD4"
                               Margin="12,8" />

                    <TextBlock Text="Library"
                               Foreground="#CFCFD4"
                               Margin="12,8" />

                    <TextBlock Text="Playlists"
                               Foreground="#CFCFD4"
                               Margin="12,8" />

                    <TextBlock Text="Now Playing"
                               Foreground="#CFCFD4"
                               Margin="12,8" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Settings"
                           Foreground="#77777D"
                           Margin="12,0,0,8" />
            </Grid>
        </Border>

        <!-- Top search -->
        <Border Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                BorderBrush="#25262B"
                BorderThickness="0,0,0,1"
                Padding="28,22">

            <Grid ColumnDefinitions="*,Auto">
                <TextBox Width="460"
                         Height="42"
                         HorizontalAlignment="Left"
                         Watermark="Search songs, artists, albums..."
                         Text="{Binding SearchQuery}" />

                <Button Grid.Column="1"
                        Content="Search"
                        Height="42"
                        Command="{Binding SearchCommand}" />
            </Grid>
        </Border>

        <!-- Search results -->
        <ScrollViewer Grid.Row="1"
                      Grid.Column="1"
                      Margin="0,30,0,0"
                      IsVisible="{Binding IsSearchView}">
            <StackPanel Spacing="24">

                <!-- Songs -->
                <StackPanel IsVisible="{Binding HasSongs}">
                    <TextBlock Text="Songs"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding SearchSongs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#18191D"
                                        BorderBrush="#2A2B31"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="46,*,Auto,Auto">
                                        <Border Width="46"
                                                Height="46"
                                                CornerRadius="8"
                                                Background="#24252B">
                                            <TextBlock Text="♪"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#A78BFA"
                                                       FontSize="20" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Margin="14,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Spacing="3">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#F2F2F2"
                                                       FontSize="15"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ArtistName}"
                                                       Foreground="#9A9AA0"
                                                       FontSize="13" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AlbumTitle}"
                                                   Foreground="#77777D"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />

                                        <Button Grid.Column="3"
                                                Content="Play"
                                                Margin="16,0,0,0"
                                                Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Albums -->
                <StackPanel IsVisible="{Binding HasAlbums}">
                    <TextBlock Text="Albums"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding SearchAlbums}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenAlbumCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Border Background="#18191D"
                                            BorderBrush="#2A2B31"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="46,*">
                                            <Border Width="46"
                                                    Height="46"
                                                    CornerRadius="8"
                                                    Background="#24252B">
                                                <TextBlock Text="♪"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#A78BFA"
                                                           FontSize="20" />
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Margin="14,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Spacing="3">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#F2F2F2"
                                                           FontSize="15"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ArtistName}"
                                                           Foreground="#9A9AA0"
                                                           FontSize="13" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Artists -->
                <StackPanel IsVisible="{Binding HasArtists}">
                    <TextBlock Text="Artists"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding SearchArtists}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenArtistCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Border Background="#18191D"
                                            BorderBrush="#2A2B31"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="46,*">
                                            <Border Width="46"
                                                    Height="46"
                                                    CornerRadius="8"
                                                    Background="#24252B">
                                                <TextBlock Text="♪"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#A78BFA"
                                                           FontSize="20" />
                                            </Border>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       Foreground="#F2F2F2"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="14,0,0,0" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Playlists -->
                <StackPanel IsVisible="{Binding HasPlaylists}">
                    <TextBlock Text="Playlists"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding SearchPlaylists}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenPlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Border Background="#18191D"
                                            BorderBrush="#2A2B31"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="46,*">
                                            <Border Width="46"
                                                    Height="46"
                                                    CornerRadius="8"
                                                    Background="#24252B">
                                                <TextBlock Text="♪"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#A78BFA"
                                                           FontSize="20" />
                                            </Border>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       Foreground="#F2F2F2"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="14,0,0,0" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Collection Detail -->
        <ScrollViewer Grid.Row="1"
                      Grid.Column="1"
                      IsVisible="{Binding IsCollectionDetailView}"
                      Margin="28,30,28,0">
            <StackPanel Spacing="16">

                <Button Content="Back"
                        Command="{Binding BackToSearchCommand}"
                        HorizontalAlignment="Left" />

                <Grid ColumnDefinitions="160,*" ColumnSpacing="24">
                    <Border Width="160"
                            Height="160"
                            CornerRadius="12"
                            Background="#24252B">
                        <TextBlock Text="♪"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#A78BFA"
                                   FontSize="48" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding CollectionDetail.CollectionType}"
                                   Opacity="0.65"
                                   FontSize="13"
                                   Foreground="#F2F2F2" />

                        <TextBlock Text="{Binding CollectionDetail.Title}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#F2F2F2" />

                        <TextBlock Text="{Binding CollectionDetail.Subtitle}"
                                   Opacity="0.75"
                                   FontSize="14"
                                   Foreground="#F2F2F2" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Loading tracks..."
                           IsVisible="{Binding CollectionDetail.IsLoading}"
                           Opacity="0.65"
                           Foreground="#F2F2F2" />

                <TextBlock Text="{Binding CollectionDetail.Error}"
                           IsVisible="{Binding CollectionDetail.HasError}"
                           Foreground="Tomato" />

                <TextBlock Text="Tracks"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#F2F2F2" />

                <ItemsControl ItemsSource="{Binding CollectionDetail.Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0">
                                <Border Background="#18191D"
                                        BorderBrush="#2A2B31"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#F2F2F2"
                                                       FontSize="15"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ArtistName}"
                                                       Opacity="0.65"
                                                       FontSize="12"
                                                       Foreground="#9A9AA0" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Duration}"
                                                   Opacity="0.65"
                                                   Foreground="#F2F2F2" />
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No tracks found."
                           Opacity="0.55"
                           Foreground="#F2F2F2"
                           IsVisible="{Binding CollectionDetail.IsEmpty}" />

            </StackPanel>
        </ScrollViewer>

        <!-- Artist Detail -->
        <ScrollViewer Grid.Row="1"
                      Grid.Column="1"
                      IsVisible="{Binding IsArtistDetailView}"
                      Margin="28,30,28,0">
            <StackPanel Spacing="20">

                <Button Content="Back"
                        Command="{Binding BackToSearchCommand}"
                        HorizontalAlignment="Left" />

                <Grid ColumnDefinitions="160,*" ColumnSpacing="24">
                    <Border Width="160"
                            Height="160"
                            CornerRadius="12"
                            Background="#24252B">
                        <TextBlock Text="♪"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#A78BFA"
                                   FontSize="48" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="Artist"
                                   Opacity="0.65"
                                   FontSize="13"
                                   Foreground="#F2F2F2" />

                        <TextBlock Text="{Binding ArtistDetail.Name}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#F2F2F2" />

                        <TextBlock Text="{Binding ArtistDetail.Subtitle}"
                                   Opacity="0.75"
                                   FontSize="14"
                                   Foreground="#F2F2F2" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Loading artist..."
                           IsVisible="{Binding ArtistDetail.IsLoading}"
                           Opacity="0.65"
                           Foreground="#F2F2F2" />

                <TextBlock Text="{Binding ArtistDetail.Error}"
                           Foreground="Tomato"
                           Opacity="0.9" />

                <StackPanel IsVisible="{Binding ArtistDetail.HasTopSongs}">
                    <TextBlock Text="Top songs"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Margin="0,0,0,8" />

                    <ItemsControl ItemsSource="{Binding ArtistDetail.TopSongs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Border Background="#18191D"
                                            BorderBrush="#2A2B31"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#F2F2F2"
                                                           FontSize="15"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding AlbumTitle}"
                                                           Opacity="0.65"
                                                           FontSize="12"
                                                           Foreground="#9A9AA0" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Duration}"
                                                       Opacity="0.65"
                                                       Foreground="#F2F2F2" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel IsVisible="{Binding ArtistDetail.HasAlbums}">
                    <TextBlock Text="Albums"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Margin="0,16,0,8" />

                    <ItemsControl ItemsSource="{Binding ArtistDetail.Albums}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="48,*" Margin="0,4">
                                    <Border Width="40"
                                            Height="40"
                                            CornerRadius="8"
                                            Background="#24252B">
                                        <TextBlock Text="♪"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#A78BFA"
                                                   FontSize="16" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#F2F2F2"
                                                   FontSize="15"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ArtistName}"
                                                   Opacity="0.65"
                                                   FontSize="12"
                                                   Foreground="#9A9AA0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel IsVisible="{Binding ArtistDetail.HasSingles}">
                    <TextBlock Text="Singles"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Margin="0,16,0,8" />

                    <ItemsControl ItemsSource="{Binding ArtistDetail.Singles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="48,*" Margin="0,4">
                                    <Border Width="40"
                                            Height="40"
                                            CornerRadius="8"
                                            Background="#24252B">
                                        <TextBlock Text="♪"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#A78BFA"
                                                   FontSize="16" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#F2F2F2"
                                                   FontSize="15"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ArtistName}"
                                                   Opacity="0.65"
                                                   FontSize="12"
                                                   Foreground="#9A9AA0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Queue -->
        <Border Grid.Row="1"
                Grid.Column="2"
                BorderBrush="#25262B"
                BorderThickness="1,0,0,0"
                Padding="26,32">

            <Grid RowDefinitions="Auto,*">
                <StackPanel>
                    <TextBlock Text="Queue"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2" />

                    <TextBlock Text="Upcoming songs"
                               FontSize="13"
                               Foreground="#77777D"
                               Margin="0,5,0,0" />
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              Margin="0,24,0,0"
                              ItemsSource="{Binding Queue}">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Margin="0,0,0,8"
                                    CornerRadius="10"
                                    Background="#15161A">

                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#F2F2F2"
                                               FontSize="14" />

                                    <TextBlock Text="{Binding ArtistName}"
                                               Foreground="#8E8E95"
                                               FontSize="12" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Bottom player -->
        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                BorderBrush="#25262B"
                BorderThickness="0,1,0,0"
                Background="#111214"
                Padding="24">

            <Grid ColumnDefinitions="*,Auto,*">
                <Grid ColumnDefinitions="52,*">
                    <Border Width="52"
                            Height="52"
                            CornerRadius="10"
                            Background="#24252B">

                        <TextBlock Text="♪"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#A78BFA"
                                   FontSize="22" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center"
                                Spacing="3">

                        <TextBlock Text="{Binding CurrentSong.Title}"
                                   Foreground="#F2F2F2"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <TextBlock Text="{Binding CurrentSong.ArtistName}"
                                   Foreground="#8E8E95"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="14">

                    <Button Content="Prev" />
                    <Button Content="Play"
                            Command="{Binding PlaySelectedCommand}" />
                    <Button Content="Next" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="12">

                    <TextBlock Text="0:00"
                               Foreground="#77777D"
                               VerticalAlignment="Center" />

                    <Border Width="160"
                            Height="4"
                            Background="#2A2B31"
                            CornerRadius="2" />

                    <TextBlock Text="0:00"
                               Foreground="#77777D"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>