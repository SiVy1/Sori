<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="App.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <StreamGeometry x:Key="IconPlay">M 0,0 L 12,6 L 0,12 Z</StreamGeometry>
        <StreamGeometry x:Key="IconPause">M 0,0 L 4,0 L 4,12 L 0,12 Z M 8,0 L 12,0 L 12,12 L 8,12 Z</StreamGeometry>
        <StreamGeometry x:Key="IconStop">M 0,0 L 12,0 L 12,12 L 0,12 Z</StreamGeometry>
        <StreamGeometry x:Key="IconNext">M 0,0 L 8,6 L 0,12 Z M 10,0 L 12,0 L 12,12 L 10,12 Z</StreamGeometry>
        <StreamGeometry x:Key="IconPrev">M 12,0 L 4,6 L 12,12 Z M 0,0 L 2,0 L 2,12 L 0,12 Z</StreamGeometry>
        <StreamGeometry x:Key="IconVolume">M 0,4 L 4,4 L 8,0 L 8,12 L 4,8 L 0,8 Z</StreamGeometry>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>